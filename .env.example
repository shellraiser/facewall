# ── Slack integration ──────────────────────────────────────────────────────────
#
# 1. Create a Slack app at https://api.slack.com/apps
# 2. Add the OAuth scope:  users:read
#    (also add users:read.email if you want email addresses)
# 3. Install the app to your workspace and copy the Bot User OAuth Token below.
#
# SLACK_TOKEN is NOT prefixed with VITE_ so it is only used by the Vite dev
# proxy and is never included in the browser bundle.

# SLACK_TOKEN=xoxb-your-bot-token-here

# Tell the client to fetch from Slack instead of the randomuser.me demo data.
# VITE_SLACK_ENABLED=true


# ── Custom employee JSON endpoint ──────────────────────────────────────────────
# Point to any URL that returns { "users": [{ email, firstName, lastName, role }] }
# This takes priority over Slack when set.
# VITE_EMPLOYEES_URL=https://your-org.example.com/api/employees


# ── Production note ────────────────────────────────────────────────────────────
# The Slack proxy only works with `vite dev`. For a production build you need a
# small backend endpoint (e.g. Express, Cloudflare Worker, or an API route in
# Next.js/Remix) that proxies /api/slack/* → https://slack.com/api/* with the
# Authorization header added server-side.
